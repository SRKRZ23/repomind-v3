# Fireworks AI API key (get from fireworks.ai — $50 hackathon credits)
# Powers the Gemma 27B fast tier. Leave blank + set AIR_GAP=1 for fully on-prem.
FIREWORKS_API_KEY=fw_...

# AMD MI300X vLLM endpoint (from AMD Developer Cloud).
# For a local/offline demo with NO GPU and NO keys, run:
#   make demo-offline   (sets AIR_GAP=1 + VLLM_BASE_URL=http://vllm-mock:8080, --profile mock)
VLLM_BASE_URL=http://YOUR_MI300X_IP:8080
VLLM_API_KEY=token-repomind

# Verified model (ACT I, single MI300X @ 256K): Qwen/Qwen3-Coder-Next-FP8 (80B/3B-active MoE).
# For a Western/open-weight option, set e.g. Qwen2.5-Coder-32B or a Llama/Mistral coder.
VLLM_MODEL=Qwen/Qwen3-Coder-Next-FP8

# Token threshold: queries below this → Gemma, above → MI300X.
ROUTING_THRESHOLD=8000

# AIR_GAP=1 → ENFORCED on-prem: all queries go to MI300X and any Fireworks egress is
# hard-refused at the client (not just routed around). Provable zero-egress mode.
AIR_GAP=0

# Comma-separated allowed CORS origins in production (default "*" for local demo).
ALLOWED_ORIGINS=*

# API auth: if set, /analyze and /cuda-to-rocm require Authorization: Bearer <key>
# (or X-API-Key). Unset = open local-demo mode.
API_KEY=

# Gemma first-pass triage (selects relevant files to feed the MI300X deep pass).
# 1 = on (smart-routing mode); auto-skipped under AIR_GAP=1.
GEMMA_TRIAGE=1

# Tamper-evident (SHA-256 hash-chained + Ed25519-signed) append-only audit log.
# Use a persistent/WORM path in production (default ./data, mounted as a compose volume).
AUDIT_LOG=data/repomind_audit.jsonl
# Ed25519 signing key (hex). Unset → ephemeral key generated (public key printed to stderr).
# Set a fixed key in production so audit signatures remain verifiable across restarts.
AUDIT_SIGNING_KEY=
